<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Shame Paradox — Reel Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #faf8f5;
    --surface: #ffffff;
    --surface2: #f5f2ed;
    --border: #e8e2d9;
    --text: #1a1612;
    --text-muted: #7a6f62;
    --accent: #2c4a6b;
    --accent-light: #e8f0f8;
    --gold: #c4963a;
    --gold-light: #fdf6e8;
    --green: #2d6a4f;
    --green-light: #d8f3e3;
    --red: #8b2635;
    --red-light: #fde8eb;
    --purple: #5c3d7a;
    --purple-light: #ede8f5;
    --orange: #c45a1a;
    --orange-light: #fdf0e6;
    --shadow: 0 2px 12px rgba(44,74,107,0.08);
    --shadow-hover: 0 6px 24px rgba(44,74,107,0.15);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: var(--accent);
    color: white;
    padding: 2.5rem 2rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(44,74,107,0.3);
  }
  header .inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }
  header h1 span {
    display: block;
    font-size: 0.95rem;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    opacity: 0.75;
    margin-top: 0.3rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .header-stats {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .stat {
    text-align: center;
  }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 600;
    line-height: 1;
    color: var(--gold);
  }
  .stat-label {
    font-size: 0.7rem;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* PROGRESS BAR */
  .progress-bar-wrap {
    background: var(--accent);
    padding: 0.8rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .progress-bar-wrap .inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .progress-track {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.2);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--gold);
    border-radius: 3px;
    transition: width 0.4s ease;
    width: 0%;
  }
  .progress-label {
    color: rgba(255,255,255,0.8);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  /* CONTROLS */
  .controls {
    max-width: 1400px;
    margin: 1.5rem auto 0;
    padding: 0 2rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .filter-btn {
    padding: 0.4rem 1rem;
    border: 1.5px solid var(--border);
    background: white;
    border-radius: 20px;
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--text-muted);
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .search-wrap {
    margin-left: auto;
    position: relative;
  }
  .search-wrap input {
    padding: 0.4rem 1rem 0.4rem 2.2rem;
    border: 1.5px solid var(--border);
    border-radius: 20px;
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    width: 220px;
    outline: none;
    background: white;
    transition: border-color 0.2s;
  }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-icon {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* MAIN */
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 2rem 4rem;
  }

  /* SECTION */
  .section {
    margin-bottom: 2.5rem;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    cursor: pointer;
    user-select: none;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
  }
  .section-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .section-progress {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .section-bar {
    width: 80px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .section-bar-fill {
    height: 100%;
    background: var(--gold);
    border-radius: 2px;
    transition: width 0.3s;
  }
  .section-count {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .toggle-icon {
    color: var(--text-muted);
    font-size: 0.8rem;
    transition: transform 0.2s;
  }
  .section.collapsed .toggle-icon { transform: rotate(-90deg); }
  .section-body { }
  .section.collapsed .section-body { display: none; }

  /* REEL CARD */
  .reel-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    margin-bottom: 0.7rem;
    transition: all 0.2s;
    overflow: visible;
  }
  .reel-card:hover {
    box-shadow: var(--shadow-hover);
    border-color: #ccc;
  }
  .reel-card.done {
    opacity: 0.6;
    background: var(--surface2);
  }
  .reel-card.done .card-text {
    text-decoration: line-through;
    color: var(--text-muted);
  }

  .card-main {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    padding: 0.9rem 1rem;
    cursor: pointer;
  }
  .card-check {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border);
    border-radius: 5px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    margin-top: 2px;
    cursor: pointer;
  }
  .card-check:hover { border-color: var(--accent); }
  .reel-card.done .card-check {
    background: var(--green);
    border-color: var(--green);
    color: white;
  }
  .card-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    flex-shrink: 0;
    min-width: 32px;
    margin-top: 1px;
  }
  .card-body { flex: 1; min-width: 0; }
  .card-type {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }
  .card-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--text);
  }
  .card-actions {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-shrink: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  /* COLOR TAG */
  .color-tag {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    transition: transform 0.15s;
    flex-shrink: 0;
  }
  .color-tag:hover { transform: scale(1.3); }
  .color-tag.priority { background: var(--red); }
  .color-tag.in-progress { background: var(--gold); }
  .color-tag.done-tag { background: var(--green); }
  .color-tag.idea { background: var(--purple); }
  .color-tag.scheduled { background: var(--orange); }
  .color-tag.clear { background: var(--border); }

  .color-picker-wrap {
    position: relative;
  }
  .color-picker-popup {
    display: none;
    position: fixed;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem;
    box-shadow: var(--shadow-hover);
    z-index: 9999;
    gap: 0.4rem;
    flex-direction: column;
    min-width: 130px;
  }
  .color-picker-popup.open { display: flex; }
  .color-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.4rem;
    border-radius: 5px;
    cursor: pointer;
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .color-option:hover { background: var(--surface2); }
  .color-dot {
    width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0;
  }

  /* STATUS DOT */
  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }
  .status-dot.none { background: transparent; }
  .status-dot.priority { background: var(--red); }
  .status-dot.in-progress { background: var(--gold); }
  .status-dot.done-tag { background: var(--green); }
  .status-dot.idea { background: var(--purple); }
  .status-dot.scheduled { background: var(--orange); }

  /* EXPAND/MEMO */
  .expand-btn {
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.15s;
    white-space: nowrap;
  }
  .expand-btn:hover {
    background: var(--accent-light);
    border-color: var(--accent);
    color: var(--accent);
  }

  .card-detail {
    padding: 0.8rem 1rem 0.9rem 3.8rem;
    border-top: 1px solid var(--border);
    background: var(--surface2);
    border-radius: 0 0 10px 10px;
    display: none;
  }
  .card-detail.open { display: block; }
  .detail-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.7rem;
    flex-wrap: wrap;
  }
  .detail-field {
    flex: 1;
    min-width: 180px;
  }
  .detail-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
    font-weight: 500;
  }
  .detail-input, .detail-textarea {
    width: 100%;
    padding: 0.45rem 0.7rem;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    background: white;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .detail-input:focus, .detail-textarea:focus { border-color: var(--accent); }
  .detail-textarea {
    min-height: 70px;
    resize: vertical;
    line-height: 1.5;
  }
  .link-preview {
    display: none;
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: var(--accent);
  }
  .link-preview a { color: inherit; }

  /* TIMELINE SECTION */
  .timeline-section {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .timeline-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .timeline-live {
    font-size: 0.7rem;
    background: var(--red);
    color: white;
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
    font-family: 'Jost', sans-serif;
    font-weight: 600;
    letter-spacing: 0.08em;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.8rem;
  }
  .timeline-card {
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    background: var(--surface2);
    transition: all 0.2s;
  }
  .timeline-card:hover { box-shadow: var(--shadow); }
  .timeline-card.completed {
    background: var(--green-light);
    border-color: var(--green);
  }
  .timeline-card.in-progress {
    background: var(--gold-light);
    border-color: var(--gold);
  }
  .tl-date {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }
  .tl-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }
  .tl-body {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
  .tl-link {
    font-size: 0.8rem;
    color: var(--accent);
    display: block;
    margin-top: 0.4rem;
    word-break: break-all;
  }
  .tl-empty {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: italic;
    padding: 1rem;
    text-align: center;
  }

  /* COLOR LEGEND */
  .legend {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding: 0.8rem 1rem;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 8px;
  }
  .legend-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-right: 0.5rem;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* SAVE INDICATOR */
  .save-toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--green);
    color: white;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s;
    z-index: 1000;
  }
  .save-toast.show {
    transform: translateY(0);
    opacity: 1;
  }

  /* HIDDEN CARD */
  .reel-card.hidden { display: none; }

  @media (max-width: 600px) {
    header { padding: 1.5rem 1rem 1rem; }
    main { padding: 1rem 1rem 3rem; }
    .controls { padding: 0 1rem; }
    .card-actions { display: none; }
    .card-detail { padding-left: 2.8rem; }
  }
</style>
</head>
<body>

<header>
  <div class="inner">
    <div>
      <h1>The Shame Paradox
        <span>YouTube Reel Production Tracker</span>
      </h1>
    </div>
    <div class="header-stats">
      <div class="stat">
        <div class="stat-number" id="total-count">402</div>
        <div class="stat-label">Total Reels</div>
      </div>
      <div class="stat">
        <div class="stat-number" id="done-count">0</div>
        <div class="stat-label">Completed</div>
      </div>
      <div class="stat">
        <div class="stat-number" id="pct">0%</div>
        <div class="stat-label">Progress</div>
      </div>
    </div>
  </div>
</header>
<div class="progress-bar-wrap">
  <div class="inner">
    <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
    <div class="progress-label" id="progress-label">0 of 402 reels published</div>
  </div>
</div>

<div class="controls">
  <button class="filter-btn active" onclick="filterCards('all', this)">All (402)</button>
  <button class="filter-btn" onclick="filterCards('todo', this)">To Do</button>
  <button class="filter-btn" onclick="filterCards('done', this)">Done ✓</button>
  <button class="filter-btn" onclick="filterCards('priority', this)">🔴 Priority</button>
  <button class="filter-btn" onclick="filterCards('in-progress', this)">🟡 In Progress</button>
  <button class="filter-btn" onclick="filterCards('scheduled', this)">🟠 Scheduled</button>
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" placeholder="Search reels..." oninput="searchCards(this.value)">
  </div>
</div>

<main>

  <!-- LEGEND -->
  <div class="legend">
    <span class="legend-title">Colour Tags:</span>
    <span class="legend-item"><span class="color-dot" style="background:var(--red)"></span> Priority</span>
    <span class="legend-item"><span class="color-dot" style="background:var(--gold)"></span> In Progress</span>
    <span class="legend-item"><span class="color-dot" style="background:var(--green)"></span> Done</span>
    <span class="legend-item"><span class="color-dot" style="background:var(--purple)"></span> Idea/Notes</span>
    <span class="legend-item"><span class="color-dot" style="background:var(--orange)"></span> Scheduled</span>
    <span class="legend-item"><span class="color-dot" style="background:var(--border)"></span> Clear</span>
  </div>

  <!-- LIVE TIMELINE -->
  <div class="timeline-section">
    <div class="timeline-title">
      Live Timeline
      <span class="timeline-live">LIVE</span>
    </div>
    <div class="timeline-grid" id="timeline-grid">
      <div class="tl-empty">No reels published yet. Complete a reel and add a link to see it appear here.</div>
    </div>
  </div>

  <!-- REEL SECTIONS -->
  <div id="sections-container"></div>

</main>

<div class="save-toast" id="save-toast">✓ Saved</div>

<script>
// ===================== DATA =====================
const SECTIONS = [
  { id: 's1', title: 'Part 1: Preface, Introduction & Chapter 1', range: '#1–40', count: 40 },
  { id: 's2', title: 'Part 2: Chapter 2 — In the Beginning Is the Face', range: '#41–77', count: 37 },
  { id: 's3', title: 'Part 3: Chapter 3 — Neurons That Fire Together', range: '#78–120', count: 43 },
  { id: 's4', title: 'Part 4: Chapter 4 — The Doorbell', range: '#121–166', count: 46 },
  { id: 's5', title: 'Part 5: Chapter 5 — The Executioner Does Not Know', range: '#167–212', count: 46 },
